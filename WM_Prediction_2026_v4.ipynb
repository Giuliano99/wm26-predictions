## 13 · Monte-Carlo-Simulation – Gruppenphase

Simuliert n=10.000 Turniere und gibt Gruppensieger-Wahrscheinlichkeiten aus.  
**Quoten fließen über das Ensemble in jede Spielsimulation ein.**

import time

def simulate_match_ensemble(team1, team2):
    """
    Simuliert ein Spiel unter Berücksichtigung der Ensemble-Wahrscheinlichkeiten.

    Vorgehen:
    1. Ensemble-Wahrscheinlichkeit bestimmt Ausgang (Sieg/Unentschieden/Niederlage)
    2. Konkretes Ergebnis wird aus Poisson-Matrix gesampelt – aber nur aus dem
       Segment das zum gewählten Ausgang passt (conditioning).
    """
    p_win1, p_draw, p_win2, _, _, _ = ensemble_probs(team1, team2)
    matrix, _, _ = dc_matrix(team1, team2)

    # Ausgang sampeln
    outcome = np.random.choice(
        ['win1', 'draw', 'win2'],
        p=[p_win1, p_draw, p_win2]
    )

    # Bedingtes Ergebnis sampeln
    n = matrix.shape[0]
    mask = np.zeros_like(matrix)
    for i in range(n):
        for j in range(n):
            if outcome == 'win1'  and i > j: mask[i,j] = matrix[i,j]
            elif outcome == 'draw' and i==j:  mask[i,j] = matrix[i,j]
            elif outcome == 'win2' and j > i: mask[i,j] = matrix[i,j]

    flat = mask.flatten()
    s = flat.sum()
    if s == 0:
        # Fallback: 1:0 / 0:0 / 0:1
        return (1,0) if outcome=='win1' else ((0,0) if outcome=='draw' else (0,1))

    idx = np.random.choice(len(flat), p=flat/s)
    r, c = divmod(idx, n)
    return int(r), int(c)


def simulate_group_ensemble(teams):
    """Simuliert eine Gruppe mit Ensemble-Wahrscheinlichkeiten."""
    table = {t: [0, 0, 0, 0] for t in teams}  # pts, gf, ga, gd
    for i in range(len(teams)):
        for j in range(i+1, len(teams)):
            t1, t2 = teams[i], teams[j]
            g1, g2 = simulate_match_ensemble(t1, t2)
            table[t1][1] += g1; table[t1][2] += g2; table[t1][3] += g1-g2
            table[t2][1] += g2; table[t2][2] += g1; table[t2][3] += g2-g1
            if g1 > g2:   table[t1][0] += 3
            elif g1 < g2: table[t2][0] += 3
            else:         table[t1][0] += 1; table[t2][0] += 1
    ranked = sorted(table.items(), key=lambda x: (x[1][0], x[1][3], x[1][1]), reverse=True)
    return ranked


N_SIM = 10_000
reach = {t: {s: 0 for s in ['1st','2nd','3rd','4th']} for g in GROUPS.values() for t in g}

print(f'Starte {N_SIM:,} Simulationen ...')
t0 = time.time()

for _ in range(N_SIM):
    for gname, teams in GROUPS.items():
        ranked = simulate_group_ensemble(teams)
        for pos, (team, _) in enumerate(ranked):
            label = ['1st','2nd','3rd','4th'][pos]
            reach[team][label] += 1

elapsed = time.time() - t0
print(f'Fertig in {elapsed:.1f}s  ({N_SIM/elapsed:.0f} Sim/s)')

# ── Gruppenplatz-Wahrscheinlichkeiten ────────────────────────────────────────
sim_rows = []
for gname, teams in sorted(GROUPS.items()):
    for team in teams:
        r = reach[team]
        sim_rows.append({
            'Gruppe': gname,
            'Team':   team,
            'Elo':    round(get_elo(model_name(team))),
            '1. Platz %':  round(r['1st'] / N_SIM * 100, 1),
            '2. Platz %':  round(r['2nd'] / N_SIM * 100, 1),
            '3. Platz %':  round(r['3rd'] / N_SIM * 100, 1),
            '4. Platz %':  round(r['4th'] / N_SIM * 100, 1),
        })

sim_df = pd.DataFrame(sim_rows)

for gname in sorted(GROUPS.keys()):
    grp = (
        sim_df[sim_df['Gruppe'] == gname]
        .sort_values('1. Platz %', ascending=False)
        .reset_index(drop=True)
    )
    grp.index += 1
    print(f'\n{"="*55}')
    print(f'  GRUPPE {gname}')
    print(f'{"="*55}')
    display(grp.drop(columns=['Gruppe']))

