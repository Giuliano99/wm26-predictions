# ── Normalisierung: Overround entfernen ─────────────────────────────────────
# Buchmacher bauen eine Marge (Overround) ein → implizite Wahrscheinlichkeiten
# summieren auf > 1. Wir normalisieren auf 1.0 (fair probabilities).
odds_lookup = {}  # (home_team, away_team) -> {home_win, draw, away_win}

for g in odds_raw['games']:
    p = g['prob']
    total = p['home_win'] + p['draw'] + p['away_win']
    odds_lookup[(g['home_team'], g['away_team'])] = {
        'home_win': p['home_win'] / total,
        'draw':     p['draw']     / total,
        'away_win': p['away_win'] / total,
    }
















































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































