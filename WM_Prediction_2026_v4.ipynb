## 6 · Form der letzten 5 Spiele

FORM_WEIGHTS = np.array([0.40, 0.25, 0.17, 0.11, 0.07])
FORM_N = len(FORM_WEIGHTS)

def match_points(score_for, score_against):
    if score_for > score_against:  return 1.0
    if score_for == score_against: return 0.5
    return 0.0

def weighted_form(dq):
    pts = list(dq)
    if not pts:
        return 0.5
    w = FORM_WEIGHTS[:len(pts)].copy()
    w /= w.sum()
    return float(np.dot(pts, w))

recent: dict = defaultdict(lambda: deque(maxlen=FORM_N))
form_home_list, form_away_list = [], []

for _, row in all_matches.iterrows():
    home, away = row['home_team'], row['away_team']
    hs, as_ = row['home_score'], row['away_score']
    form_home_list.append(weighted_form(recent[home]))
    form_away_list.append(weighted_form(recent[away]))
    recent[home].appendleft(match_points(hs, as_))
    recent[away].appendleft(match_points(as_, hs))

all_matches['form_home'] = form_home_list
all_matches['form_away'] = form_away_list
all_matches['form_diff'] = all_matches['form_home'] - all_matches['form_away']

def get_current_form(team):
    return weighted_form(recent[team])

print('Form-Feature berechnet.')
print(f'form_diff Bereich: {all_matches["form_diff"].min():.2f} – {all_matches["form_diff"].max():.2f}')

## 7 · Poisson-Modell

model_matches = model_matches.join(
    all_matches[['elo_home', 'elo_away', 'elo_diff', 'form_home', 'form_away', 'form_diff']],
    how='left'
)

def tournament_weight(tournament):
    t = str(tournament)
    if 'FIFA World Cup' in t:           return 20
    if 'UEFA Euro' in t:                return 15
    if 'Copa América' in t:             return 15
    if 'African Cup of Nations' in t:   return 15
    if 'AFC Asian Cup' in t:            return 15
    if 'OFC Nations Cup' in t:          return 15
    if 'Nations League' in t:           return 8
    if 'qualification' in t.lower():    return 8
    if 'Friendly' in t:                 return 1
    return 2

model_matches['tournament_weight'] = model_matches['tournament'].apply(tournament_weight)
days_old = (pd.Timestamp.now() - model_matches['date']).dt.days
model_matches['time_weight'] = np.exp(-days_old / 1460)
model_matches['weight'] = model_matches['tournament_weight'] * model_matches['time_weight']

home_df = model_matches[['home_team','away_team','home_score','weight','elo_diff','form_diff']].copy()
home_df.columns = ['team','opponent','goals','weight','elo_diff','form_diff']

away_df = model_matches[['away_team','home_team','away_score','weight','elo_diff','form_diff']].copy()
away_df.columns = ['team','opponent','goals','weight','elo_diff','form_diff']
away_df['elo_diff']  = -away_df['elo_diff']
away_df['form_diff'] = -away_df['form_diff']

goal_model_data = pd.concat([home_df, away_df], ignore_index=True)

model = smf.glm(
    formula='goals ~ team + opponent + elo_diff + form_diff',
    data=goal_model_data,
    family=sm.families.Poisson(),
    freq_weights=goal_model_data['weight']
).fit()

print('Poisson-Modell trainiert.')
print(f'AIC: {model.aic:.1f}')

## 8 · Dixon-Coles-Korrektur

RHO = 0.07

def dixon_coles_tau(x, y, mu1, mu2, rho=RHO):
    if   x == 0 and y == 0: return 1.0 - mu1 * mu2 * rho
    elif x == 1 and y == 0: return 1.0 + mu2 * rho
    elif x == 0 and y == 1: return 1.0 + mu1 * rho
    elif x == 1 and y == 1: return 1.0 - rho
    return 1.0

print(f'Dixon-Coles RHO = {RHO}')

## 9 · Vorhersagefunktionen mit Quoten-Ensemble

### Architektur

```
Poisson-Modell (40%)     Buchmacher-Quoten (60%)
  ↓                           ↓
P(home_win | Modell)    P(home_win | Markt)
  ↓                           ↓
         Ensemble-Mix
              ↓
   Finale P(home_win / draw / away_win)
              ↓
   Erwartetes Ergebnis für Tippspiel
```

**Warum Quoten nur hier?**  
Quoten sind forward-looking (Marktwissen, Verletzungen, Aufstellungen) aber nur für kommende Spiele verfügbar.  
Elo und Poisson trainieren auf historischen Daten → bleiben unberührt.

# Name-Mapping: Quoten-Namen → Modell-Namen
# Die Buchmacher verwenden teilweise andere Schreibweisen als results.csv
ODDS_TO_MODEL = {
    'USA':                    'United States',
    'Ivory Coast':            'Ivory Coast',
    'Bosnia & Herzegovina':   'Bosnia and Herzegovina',
    'DR Congo':               'DR Congo',
    'Czech Republic':         'Czech Republic',
    'South Korea':            'South Korea',
    'New Zealand':            'New Zealand',
    'Saudi Arabia':           'Saudi Arabia',
    'Cape Verde':             'Cape Verde',
    'South Africa':           'South Africa',
}

# Gruppen-Namen → Modell-Namen
GROUP_TO_MODEL = {
    'Czech Republic':         'Czech Republic',
    'Bosnia and Herzegovina': 'Bosnia and Herzegovina',
    'United States':          'United States',
    'Ivory Coast':            'Ivory Coast',
    'New Zealand':            'New Zealand',
    'Saudi Arabia':           'Saudi Arabia',
    'Cape Verde':             'Cape Verde',
    'South Africa':           'South Africa',
    'South Korea':            'South Korea',
    'DR Congo':               'DR Congo',
    'Curacao':                'Curacao',
}

def model_name(team):
    return GROUP_TO_MODEL.get(team, team)

def odds_name(team):
    """Konvertiert Gruppen-/Modell-Namen → Quoten-Namen."""
    reverse = {v: k for k, v in ODDS_TO_MODEL.items()}
    return reverse.get(team, team)


def get_odds_probs(team1, team2):
    """
    Sucht Quoten-Wahrscheinlichkeiten für (team1, team2).
    Probiert beide Richtungen (home/away vertauscht).
    Gibt (home_win, draw, away_win) aus Sicht von team1 zurück.
    Falls keine Quoten vorhanden: None.
    """
    t1_odds = odds_name(team1)
    t2_odds = odds_name(team2)

    # Direkte Richtung
    key = (t1_odds, t2_odds)
    if key in odds_lookup:
        p = odds_lookup[key]
        return p['home_win'], p['draw'], p['away_win']

    # Umgekehrte Richtung → Wahrscheinlichkeiten tauschen
    key_rev = (t2_odds, t1_odds)
    if key_rev in odds_lookup:
        p = odds_lookup[key_rev]
        return p['away_win'], p['draw'], p['home_win']

    return None


def predict_goals(team, opponent):
    """Erwartete Tore von team gegen opponent (Poisson-Modell)."""
    params     = model.params
    elo_diff   = get_elo(team) - get_elo(opponent)
    form_diff  = get_current_form(team) - get_current_form(opponent)
    lp = float(params.get('Intercept', 0.0))
    lp += float(params.get(f'team[T.{team}]', 0.0))
    lp += float(params.get(f'opponent[T.{opponent}]', 0.0))
    lp += float(params.get('elo_diff', 0.0)) * elo_diff
    lp += float(params.get('form_diff', 0.0)) * form_diff
    return float(np.exp(lp))


def dc_matrix(team1, team2, max_goals=8):
    """Poisson + Dixon-Coles Ergebnis-Matrix."""
    g1 = predict_goals(model_name(team1), model_name(team2))
    g2 = predict_goals(model_name(team2), model_name(team1))
    matrix = np.outer(
        poisson.pmf(range(max_goals + 1), g1),
        poisson.pmf(range(max_goals + 1), g2)
    )
    for x in range(2):
        for y in range(2):
            matrix[x, y] *= dixon_coles_tau(x, y, g1, g2)
    matrix /= matrix.sum()
    return matrix, g1, g2


def ensemble_probs(team1, team2):
    """
    Kombiniert Poisson-Modell mit Buchmacher-Quoten.

    Rückgabe: (p_win1, p_draw, p_win2, g1, g2, source)
    - source: 'ensemble' | 'model_only'

    Strategie:
    1. Poisson+DC liefert Score-Matrix → aggregiere zu 1X2
    2. Wenn Quoten vorhanden: gewichtetes Mittel
    3. Wenn keine Quoten: reines Modell
    """
    matrix, g1, g2 = dc_matrix(team1, team2)

    # Modell-Wahrscheinlichkeiten
    p_win1_m = float(np.sum(np.tril(matrix, -1)))
    p_draw_m = float(np.sum(np.diag(matrix)))
    p_win2_m = float(np.sum(np.triu(matrix,  1)))

    odds_p = get_odds_probs(team1, team2)

    if odds_p is not None:
        p_win1_o, p_draw_o, p_win2_o = odds_p
        p_win1 = MODEL_WEIGHT * p_win1_m + ODDS_WEIGHT * p_win1_o
        p_draw = MODEL_WEIGHT * p_draw_m + ODDS_WEIGHT * p_draw_o
        p_win2 = MODEL_WEIGHT * p_win2_m + ODDS_WEIGHT * p_win2_o
        source = 'ensemble'
    else:
        p_win1, p_draw, p_win2 = p_win1_m, p_draw_m, p_win2_m
        source = 'model_only'

    # Normalisieren (Ensemble kann minimal von 1 abweichen)
    total = p_win1 + p_draw + p_win2
    return p_win1/total, p_draw/total, p_win2/total, g1, g2, source


def tipp_ergebnis(team1, team2, max_goals=8):
    """
    Berechnet das optimale Tipp-Ergebnis für ein Spiel.

    Strategie:
    1. Ensemble-Wahrscheinlichkeit gibt den Ausgang vor (Sieg/Unentschieden/Niederlage)
    2. Das konkrete Ergebnis wird aus der Poisson-Matrix gewählt:
       - Sieg team1  → wahrscheinlichstes Ergebnis mit i > j
       - Unentschieden → wahrscheinlichstes i:i Ergebnis
       - Sieg team2  → wahrscheinlichstes Ergebnis mit j > i

    Rückgabe: (tore1, tore2, p_win1, p_draw, p_win2, source)
    """
    p_win1, p_draw, p_win2, g1, g2, source = ensemble_probs(team1, team2)
    matrix, _, _ = dc_matrix(team1, team2, max_goals)

    outcome = max(
        [('win1', p_win1), ('draw', p_draw), ('win2', p_win2)],
        key=lambda x: x[1]
    )[0]

    best_score = None
    best_prob  = -1

    for i in range(max_goals + 1):
        for j in range(max_goals + 1):
            p = matrix[i, j]
            if outcome == 'win1'  and i > j and p > best_prob:
                best_score, best_prob = (i, j), p
            elif outcome == 'draw' and i == j and p > best_prob:
                best_score, best_prob = (i, j), p
            elif outcome == 'win2' and j > i and p > best_prob:
                best_score, best_prob = (i, j), p

    t1, t2 = best_score
    return t1, t2, p_win1, p_draw, p_win2, source


print('Vorhersagefunktionen bereit.')

# Sanity-Check
t1, t2, pw1, pd_, pw2, src = tipp_ergebnis('Germany', 'France')
print(f'\nSanity-Check Germany vs France:')
print(f'  Tipp: {t1}:{t2}  |  Quelle: {src}')
print(f'  Germany Sieg: {pw1:.1%}  |  Unentschieden: {pd_:.1%}  |  France Sieg: {pw2:.1%}')

## 10 · Kompletter Gruppenplan – Tipp-Tabelle

Für **alle 48 Gruppenspiele** wird das wahrscheinlichste Ergebnis ausgegeben,  
optimiert auf das Tippspiel (häufigster Ausgang × wahrscheinlichstes konkretes Ergebnis).

# Alle 12 Gruppen der WM 2026
GROUPS = {
    'A': ['Mexico',        'South Africa',           'South Korea',   'Czech Republic'],
    'B': ['Canada',        'Bosnia and Herzegovina', 'Qatar',         'Switzerland'],
    'C': ['Brazil',        'Morocco',                'Haiti',         'Scotland'],
    'D': ['United States', 'Paraguay',               'Australia',     'Turkey'],
    'E': ['Germany',       'Curacao',                'Ivory Coast',   'Ecuador'],
    'F': ['Netherlands',   'Japan',                  'Sweden',        'Tunisia'],
    'G': ['Belgium',       'Egypt',                  'Iran',          'New Zealand'],
    'H': ['Spain',         'Cape Verde',             'Saudi Arabia',  'Uruguay'],
    'I': ['France',        'Senegal',                'Iraq',          'Norway'],
    'J': ['Argentina',     'Algeria',                'Austria',       'Jordan'],
    'K': ['Portugal',      'DR Congo',               'Uzbekistan',    'Colombia'],
    'L': ['England',       'Croatia',                'Ghana',         'Panama'],
}

# Alle Gruppenspiele erzeugen (jeder gegen jeden)
schedule = []
for gname, teams in GROUPS.items():
    for i in range(len(teams)):
        for j in range(i+1, len(teams)):
            schedule.append((gname, teams[i], teams[j]))

print(f'{len(schedule)} Gruppenspiele gesamt (12 Gruppen × 6 Spiele)')

tipp_rows = []

for gname, t1, t2 in schedule:
    g1, g2, pw1, pd_, pw2, src = tipp_ergebnis(t1, t2)

    # Confidence = Wahrscheinlichkeit des vorhergesagten Ausgangs
    confidence = max(pw1, pd_, pw2)
    outcome_label = (
        f'{t1} Sieg' if pw1 >= pd_ and pw1 >= pw2
        else ('Unentschieden' if pd_ >= pw2
        else f'{t2} Sieg')
    )

    tipp_rows.append({
        'Gruppe':        gname,
        'Team 1':        t1,
        'Team 2':        t2,
        'Tipp':          f'{g1}:{g2}',
        'Ausgang':       outcome_label,
        'Confidence':    f'{confidence:.0%}',
        f'{t1} Sieg':    f'{pw1:.0%}',
        'Unentschieden': f'{pd_:.0%}',
        f'{t2} Sieg':    f'{pw2:.0%}',
        'Quelle':        src,
        'Elo T1':        round(get_elo(model_name(t1))),
        'Elo T2':        round(get_elo(model_name(t2))),
    })

tipp_df = pd.DataFrame(tipp_rows)
print(f'Tipps berechnet: {len(tipp_df)} Spiele')
print(f'Davon mit Quoten: {(tipp_df["Quelle"] == "ensemble").sum()}')
print(f'Nur Modell:       {(tipp_df["Quelle"] == "model_only").sum()}')

# ── Ausgabe nach Gruppen ─────────────────────────────────────────────────────
display_cols = ['Team 1', 'Team 2', 'Tipp', 'Ausgang', 'Confidence', 'Quelle']

for gname in sorted(GROUPS.keys()):
    grp = tipp_df[tipp_df['Gruppe'] == gname][display_cols].reset_index(drop=True)
    grp.index += 1
    print(f'\n{"="*60}')
    print(f'  GRUPPE {gname}:  {", ".join(GROUPS[gname])}')
